# Crucible — Phase 0 environment. Copy to `.env` and fill in. NEVER commit `.env`.

# intervals.icu — Settings → Developer → API key
# Auth is HTTP Basic: username "API_KEY", password = this key.
INTERVALS_API_KEY=

# Your intervals.icu athlete id. Find it in the URL when logged in
# (e.g. https://intervals.icu/athlete/i12345/...) or leave blank to use "0" (self).
INTERVALS_ATHLETE_ID=

# How many days back the Phase 0 verify pulls (default 30).
INTERVALS_LOOKBACK_DAYS=30

# Athlete timezone for local-calendar-date bucketing (IANA name).
ATHLETE_TZ=Pacific/Auckland

# --- Later phases (not needed for Phase 0) ---
# GEMINI_API_KEY=
# COACH_PROVIDER=gemini
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
