# Crucible mobile app — client-safe Supabase config.
# Copy to `.env` in THIS directory (apps/mobile/.env) — Expo loads env files from the
# app root, not the monorepo root. Only EXPO_PUBLIC_* vars are exposed to the client;
# never put the service_role key here (that stays in the repo-root .env for db-seed.ts).

# Project Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=

# Project Settings → API → Project API keys → anon / public (safe for the client; RLS
# is what actually protects the data, not this key)
EXPO_PUBLIC_SUPABASE_ANON_KEY=
